APP_PORT=8080
APP_BASE_URL=http://localhost:8080
AUTH_SECRET=change-this-to-a-long-random-string
ADMIN_USERS=
TRUST_PROXY_HOPS=1
IDLE_SHUTDOWN_MINUTES=10
SQLITE_FILE=/data/rabbitclone.sqlite

WORKER_IMAGE=ghcr.io/nekosuneprojects/rabbitclone-worker:main
AUTO_PULL_WORKER_IMAGE=1
WORKER_NETWORK=rabbitclone_net
MEDIA_NODES=
RTSP_INTERNAL_BASE=rtsp://mediamtx:8554
RTSP_PUBLIC_BASE=rtspt://localhost:8554

CAPTURE_SIZE=1280x720
FPS=30
VIDEO_BITRATE=2500k
AUDIO_BITRATE=128k
ENABLE_BROWSER_AUDIO=1
